{
  "name": "bandyresultatv3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "dev:host": "vite dev --port 3000 --host",
    "build": "oxlint --type-aware --type-check && vite build",
    "serve": "vite preview",
    "test": "vitest run",
    "lint": "oxlint",
    "lint:types": "oxlint --type-aware --type-check",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "check": "oxfmt --write . && oxlint --fix",
    "typecheck": "tsc --extendedDiagnostics",
    "typecheck:go": "tsgo --extendedDiagnostics --project tsconfig-go.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio",
    "database:dev": "docker compose --profile dev down && docker compose --profile dev up -d",
    "database:test": "docker compose --profile test down && docker compose --profile test up -d",
    "database:alldown": "docker compose --profile '*' down"
  },
